{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{js,ts,sh}"],
      "project": ["**/*.{js,ts,tsx}"]
    },
    "apps/*": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "src/pages/**/*.{ts,tsx}",
        "next.config.{js,mjs,ts}"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": [
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/node_modules/**"
  ],
  "ignoreDependencies": ["@types/*"]
}
