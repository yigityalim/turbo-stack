{
  "name": "turbo-stack",
  "version": "0.0.0",
  "private": true,
  "description": "A production-ready bun + Turborepo monorepo template",
  "author": {
    "name": "Mehmet Yiğit Yalım",
    "email": "contact@mehmetyigityalim.com",
    "url": "https://mehmetyigityalim.com/en"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "typecheck": "turbo run type-check",
    "test": "turbo run test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint-staged": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "checkdeps": "bash scripts/check-deps.sh",
    "clean": "bash scripts/clean.sh",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff",
    "db:reset": "supabase db reset",
    "generate-types": "supabase gen types typescript --linked --schema public > packages/types/src/database.ts",
    "rust:check": "cargo check --manifest-path crates/Cargo.toml",
    "build:wasm": "wasm-pack build crates/hashing --target bundler --out-dir pkg"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@turbo/gen": "2.9.18",
    "knip": "6.18.0",
    "lefthook": "2.1.9",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "@biomejs/biome",
    "lefthook",
    "turbo"
  ],
  "catalog": {
    "typescript": "5.9.2",
    "@types/bun": "1.3.14",
    "@types/node": "24.12.0",
    "zod": "4.3.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "16.1.7",
    "babel-plugin-react-compiler": "1.0.0",
    "@t3-oss/env-nextjs": "0.13.10",
    "tailwindcss": "4.1.18",
    "@tailwindcss/postcss": "4.2.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0",
    "class-variance-authority": "0.7.1",
    "@radix-ui/react-slot": "1.2.4",
    "lucide-react": "0.577.0",
    "tw-animate-css": "1.4.0",
    "resend": "6.6.0",
    "react-email": "3.0.7",
    "@react-email/components": "0.0.31",
    "@react-email/render": "1.4.0",
    "hono": "4.12.27",
    "tsup": "8.5.0"
  },
  "workspaces": [
    "apps/*",
    "apps/marketing/*",
    "packages/*",
    "packages/core/*",
    "packages/infra/*",
    "tooling/*"
  ]
}
