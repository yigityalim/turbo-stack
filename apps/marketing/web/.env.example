# @repo/marketing-web — environment variables.
#
# Copy to .env.local and fill. Real values are NEVER committed (only this
# example is). Next.js loads these; Turbo just hashes them for caching.

# Public site URL — exposed to the browser. NEXT_PUBLIC_* are auto-inferred by
# Turbo, so they don't need declaring in turbo.json.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
