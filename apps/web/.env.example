# @repo/web — environment variables.
#
# Copy to .env.local and fill. Real values are NEVER committed (only this
# example is). NEXT_PUBLIC_* are auto-inferred by Turbo; server-only vars must
# be declared in turbo.json `env`.

# Supabase — project API settings (new publishable/secret key format).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Optional per-app auth storage key so apps on the same domain don't collide.
NEXT_PUBLIC_SUPABASE_STORAGE_KEY="turbo-stack-web"

# Server-only, bypasses RLS — only needed if you use @repo/db/admin. When you
# enable it, also add "SUPABASE_SECRET_KEY" to this app's turbo.json `env`.
# SUPABASE_SECRET_KEY="sb_secret_..."
